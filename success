window.addEventListener('load', async () => {
  const raw = localStorage.getItem('ask_purchase_data');
  if(!raw){ document.getElementById('shareUrl').textContent='No profile data found.'; document.getElementById('viewPageBtn').textContent='← Create Your Assistant'; document.getElementById('viewPageBtn').href='/create'; return; }
  const data = JSON.parse(raw);
  if(data.chosenUsername) data.requestedSlug = data.chosenUsername;
  const savedAvatar = sessionStorage.getItem('ask_avatar');
  if(savedAvatar && savedAvatar.length < 100000) {
    data.avatar = savedAvatar;
  }
  try {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 10000);
    const res = await fetch(ASK_SERVER+'/save', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(data),
      signal: ctrl.signal
    });
    clearTimeout(timer);
    const result = await res.json();
    if(result.slug){
      slug = result.slug;
      shareUrl = BASE_URL + '/' + slug;
      document.getElementById('shareUrl').textContent = shareUrl;
      document.getElementById('viewPageBtn').href = shareUrl;
      document.getElementById('faqLink').href = '/faq?slug='+slug;
      localStorage.removeItem('ask_purchase_data');
      renderPlatformContent();
      if(data.email){
        fetch('https://menoslabs-contact.thedobrien.workers.dev',{
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({
            name: data.name,
            email: data.email,
            subject: 'Your Ask assistant is live — ' + data.name,
            html: buildConfirmationEmail(data.name, shareUrl, slug)
          })
        }).catch(()=>{});
      }
    } else {
      document.getElementById('shareUrl').textContent='Save failed. Error: '+(result.error||'Unknown');
    }
  } catch(e){
    document.getElementById('shareUrl').textContent = e.name==='AbortError' ? 'Save timed out — please contact hello@menoslabs.com' : 'Error: '+e.message;
  }
});
