function getEmbedCode(type){
  if(type==='chat'){
    return `<script src="https://ask.menoslabs.com/embed.js" data-slug="${slug}"><\/script>`;
  } else {
    return `<iframe src="${shareUrl}" width="100%" height="700" frameborder="0" style="border:none;border-radius:4px;" title="Ask ${slug}"></iframe>`;
  }
}

let currentPlatform = 'wix';

let rawEmbedCode = '';
function renderPlatformContent(){
  if(!slug){ document.getElementById('platform-content').innerHTML = '<div style="font-size:0.82rem;color:var(--text3);padding:1rem 0;">Loading your embed code...</div>'; return; }
  const steps = INSTRUCTIONS[currentPlatform][embedType];
  rawEmbedCode = getEmbedCode(embedType);
  const stepsHtml = steps.map((s,i)=>`<div class="step-item"><div class="step-circle">${i+1}</div><div class="step-text">${s}</div></div>`).join('');
  document.getElementById('platform-content').innerHTML = `
    <div class="step-list">${stepsHtml}</div>
    <div class="code-block" id="embedCodeBlock">${escapeHtml(rawEmbedCode)}</div>
    <button class="copy-btn" onclick="copyEmbed()">Copy Code</button>
    <p style="font-size:0.72rem;color:var(--text3);margin-top:0.75rem;line-height:1.6;">💡 <strong style="color:var(--text2);">Save this code</strong> — paste it into a Google Doc or Notes app so you always have it handy.</p>
  \`;
}

function escapeHtml(str){
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function selectEmbed(type){
  embedType = type;
  document.getElementById('opt-chat').classList.toggle('active', type==='chat');
  document.getElementById('opt-full').classList.toggle('active', type==='full');
  renderPlatformContent();
}

function selectPlatform(p, btn){
  currentPlatform = p;
  document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  renderPlatformContent();
}

function copyUrl(){
  navigator.clipboard.writeText(shareUrl).then(()=>{
    const btn = document.getElementById('copyUrlBtn');
    btn.textContent='Copied!'; btn.classList.add('copied');
    setTimeout(()=>{ btn.textContent='Copy'; btn.classList.remove('copied'); }, 2000);
  });
}

function copyEmbed(){
  const code = rawEmbedCode || getEmbedCode(embedType);
  navigator.clipboard.writeText(code).then(()=>{
    const btns = document.querySelectorAll('.copy-btn');
    btns.forEach(b=>{ if(b.onclick?.toString().includes('copyEmbed')){ b.textContent='Copied!'; b.classList.add('copied'); setTimeout(()=>{ b.textContent='Copy Code'; b.classList.remove('copied'); },2000); } });
  });
}

// Load and save on arrival from Stripe
window.addEventListener('load', async () => {
  const raw = localStorage.getItem('ask_purchase_data');
  if(!raw){ document.getElementById('shareUrl').textContent='No data found — please go back and try again.'; return; }

  const data = JSON.parse(raw);
  // Re-attach avatar from separate sessionStorage
  const savedAvatar = sessionStorage.getItem('ask_avatar');
  if(savedAvatar) data.avatar = savedAvatar;

  try {
    const res = await fetch(ASK_SERVER+'/save', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify(data)
    });
    const result = await res.json();
    if(result.slug){
      slug = result.slug;
      localStorage.setItem('ask_pdf_name', data.name||'Your Assistant');
      shareUrl = `https://ask.menoslabs.com/${slug}`;
      document.getElementById('shareUrl').textContent = shareUrl;
      document.getElementById('viewPageBtn').href = shareUrl;
      const faqLink = document.getElementById('faqLink');
      if(faqLink) faqLink.href = '/faq.html?slug=' + slug;
      localStorage.removeItem('ask_purchase_data');
      renderPlatformContent();
      // Send confirmation email
      console.log("Email field:", data.email);
      if(data.email){
        fetch('https://menoslabs-contact.thedobrien.workers.dev', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({
            name: data.name,
            email: data.email,
            subject: `Your Ask assistant is live — ${data.name}`,
            html: `<p>Hi ${data.name},</p>
<p>Your personal AI assistant is live! Here's your permanent link:</p>
<p><strong><a href="${shareUrl}">${shareUrl}</a></strong></p>
<p>Share it in your email signature, LinkedIn profile, or anywhere you want people to learn about you.</p>
<p>To embed a chat button on your existing website, visit your page and click the embed instructions.</p>
<br>
<p>Need help embedding or have questions? Visit our <a href="https://ask.menoslabs.com/faq.html?slug=${slug}">Help & FAQ page</a>.</p>
<br>
<p>The Menos Labs Team<br>
<a href="https://menoslabs.com">menoslabs.com</a></p>`
          })
        }).catch(()=>{});
      }
    }
  } catch(e){
    document.getElementById('shareUrl').textContent='Error saving — please contact hello@menoslabs.com';
  }
});

