<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
const WORKER = 'https://spring-pine-fd21.thedobrien.workers.dev/';
const STRIPE_URL = 'https://buy.stripe.com/aFa8wR9fo6Er9l87JSgEg00';
const STRIPE_URL_CUSTOM = 'STRIPE_CUSTOM_LINK_HERE'; // ← swap in live custom Stripe link
const ASK_SERVER = 'https://ask-server.thedobrien.workers.dev';
let systemPrompt='', chatHistory=[], chatLoading=false, chatOpen=false, avatarDataUrl=null;
let isEditMode = false, editSlug = '';
let currentFont = 'classic';
let activeEditEl = null;

// ── FONT ──
function setFont(name){
  currentFont = name;
  document.body.className = document.body.className.replace(/font-\w+/g,'').trim();
  document.body.classList.add('font-' + name);
  document.querySelectorAll('.fmt-font-btn').forEach(b => b.classList.toggle('on', b.dataset.font === name));
  autoSave();
}

// ── ALIGNMENT ──
function setAlign(dir){
  if(!activeEditEl) return;
  activeEditEl.style.textAlign = dir;
  activeEditEl.dataset.align = dir;
  ['left','center','right'].forEach(d => {
    document.getElementById('fmt-' + d).classList.toggle('on', d === dir);
  });
  activeEditEl.focus();
  autoSave();
}

// ── TOOLBAR POSITIONING ──
function showToolbar(el){
  activeEditEl = el;
  const toolbar = document.getElementById('fmt-toolbar');
  const rect = el.getBoundingClientRect();
  toolbar.classList.add('visible');
  const top = Math.max(rect.top + window.scrollY - toolbar.offsetHeight - 8, window.scrollY + 60);
  const left = Math.min(rect.left + window.scrollX, window.innerWidth - toolbar.offsetWidth - 16);
  toolbar.style.top = top + 'px';
  toolbar.style.left = Math.max(left, 8) + 'px';
  const align = el.dataset.align || el.style.textAlign || 'left';
  ['left','center','right'].forEach(d => document.getElementById('fmt-' + d).classList.toggle('on', d === align));
}

function hideToolbar(e){
  const toolbar = document.getElementById('fmt-toolbar');
  if(e.relatedTarget && toolbar.contains(e.relatedTarget)) return;
  setTimeout(() => {
    if(!toolbar.matches(':focus-within') && document.activeElement !== activeEditEl){
      toolbar.classList.remove('visible');
      activeEditEl = null;
      autoSave();
    }
  }, 100);
}

// ── AUTO SAVE ──
function autoSave(){
  const raw = sessionStorage.getItem('ask_draft');
  if(!raw) return;
  const name = document.getElementById('profileName').textContent.trim();
  if(!name || name === '—') return;
  const d = JSON.parse(raw);
  d.name = name;
  d.meta = document.getElementById('profileMeta').textContent.trim();
  d.bio = document.getElementById('profileBio').textContent.trim();
  d.font = currentFont;
  d.alignName = document.getElementById('profileName').dataset.align || 'left';
  d.alignMeta = document.getElementById('profileMeta').dataset.align || 'left';
  d.alignBio = document.getElementById('profileBio').dataset.align || 'left';
  if(d.systemPrompt) d.systemPrompt = d.systemPrompt.replace(/Bio:[\s\S]*?\n/, 'Bio: ' + d.bio + '\n');
  sessionStorage.setItem('ask_draft', JSON.stringify(d));
}

// Wire up contenteditable fields for toolbar
function wireEditableFields(){
  // Prevent toolbar buttons from stealing focus away from contenteditable
  document.getElementById('fmt-toolbar').addEventListener('mousedown', e => e.preventDefault());
  document.querySelectorAll('[contenteditable="true"]').forEach(el => {
    el.addEventListener('focus', () => showToolbar(el));
    el.addEventListener('blur', hideToolbar);
  });
}

window.addEventListener('load', () => {
  const raw = sessionStorage.getItem('ask_draft');
  if(!raw){ window.location.href='/create_custom'; return; }
  const d = JSON.parse(raw);

  isEditMode = !!d.isEdit;
  editSlug = d.editSlug || '';

  // Update purchase button label based on plan
  if(d.plan === 'custom'){
    const btn = document.getElementById('btnPurchase');
    if(btn) btn.textContent = 'Unlock My Assistant — $15.99 →';
    const modalBtn = document.querySelector('.btn-buy');
    if(modalBtn) modalBtn.textContent = 'Unlock — $15.99 →';
  }

  // Show correct banner
  if(isEditMode){
    document.getElementById('purchaseBanner').style.display = 'none';
    document.getElementById('editBanner').style.display = 'flex';
    document.getElementById('purchaseModal').style.display = 'none';
    document.querySelector('.nav-badge').textContent = 'Edit Mode';
    // Disable idle timer purchase modal in edit mode
  }

  if(d.theme && d.theme !== 'classic'){
    document.documentElement.className = d.theme;
    document.querySelectorAll('.ts-btn').forEach(b=>b.classList.toggle('on',b.dataset.theme===d.theme));
  }

  // Apply font
  if(d.font){
    currentFont = d.font;
    document.body.classList.add('font-' + d.font);
    document.querySelectorAll('.fmt-font-btn').forEach(b => b.classList.toggle('on', b.dataset.font === d.font));
  } else {
    document.body.classList.add('font-classic');
  }

  systemPrompt = d.systemPrompt;
  // Apply brand colors
  if(d.customColors){
    const c = d.customColors;
    const aC = c.accentDark || c.accent;
    const bT = c.buttonText || '#ffffff';
    document.documentElement.style.setProperty('--custom-accent', c.accent);
    document.documentElement.style.setProperty('--custom-accent-dark', aC);
    document.documentElement.style.setProperty('--custom-bg', c.bg);
    document.documentElement.style.setProperty('--custom-button', c.buttonBg);
    document.documentElement.style.setProperty('--custom-button-text', bT);
    document.documentElement.classList.add('custom');
    // Force hero bg as inline style — CSS vars on profile-hero are unreliable
    const hero = document.querySelector('.profile-hero');
    if(hero) hero.style.background = c.bg;
  }
  avatarDataUrl = d.avatar || sessionStorage.getItem('ask_avatar');
  if(d.avatar) { sessionStorage.setItem('ask_avatar', d.avatar); delete d.avatar; sessionStorage.setItem('ask_draft', JSON.stringify(d)); }

  document.getElementById('profileName').textContent = d.name||'—';
  document.getElementById('profileMeta').textContent = [d.title,d.city].filter(Boolean).join(' · ');
  document.getElementById('profileBio').textContent = d.bio||'';

  // Apply saved alignments
  if(d.alignName){ document.getElementById('profileName').style.textAlign = d.alignName; document.getElementById('profileName').dataset.align = d.alignName; }
  if(d.alignMeta){ document.getElementById('profileMeta').style.textAlign = d.alignMeta; document.getElementById('profileMeta').dataset.align = d.alignMeta; }
  if(d.alignBio){ document.getElementById('profileBio').style.textAlign = d.alignBio; document.getElementById('profileBio').dataset.align = d.alignBio; }
  document.title = `Preview — ${d.name}`;

  const firstName = d.name.split(' ')[0];
  document.getElementById('chatLabel').textContent = `Try Asking ${firstName}`;
  document.getElementById('chatPanelName').textContent = `Ask ${firstName}`;

  if(avatarDataUrl){
    document.getElementById('profileAvatar').innerHTML=`<img src="${avatarDataUrl}" alt="avatar">`;
  } else {
    const p=d.name.split(' ').filter(Boolean);
    const i=p.length>=2?p[0][0]+p[p.length-1][0]:p[0]?.[0]||'?';
    document.getElementById('profileInitials').textContent=i.toUpperCase();
  }

  // Socials
  const socials = document.getElementById('profileSocials');
  const socialLinks = [
    {key:'linkedin',label:'LinkedIn'},
    {key:'github',label:'GitHub'},
    {key:'portfolio',label:'Portfolio'},
    {key:'twitter',label:'X'},
    {key:'tiktok',label:'TikTok'},
    {key:'instagram',label:'Instagram'},
  ];
  socialLinks.forEach(({key,label})=>{
    if(d.socials?.[key]){
      const a=document.createElement('a');
      a.href=d.socials[key].startsWith('http')?d.socials[key]:'https://'+d.socials[key];
      a.className='social-pill';a.target='_blank';a.textContent=label;
      socials.appendChild(a);
    }
  });

  if(d.email){
    const a=document.createElement('a');
    const subject=encodeURIComponent('Reaching out via Ask — '+d.name);
    a.href='mailto:'+d.email+'?subject='+subject;
    a.className='social-pill';a.textContent='✉ Email Me';
    socials.appendChild(a);
  }

  // Experience
  if(d.experience && d.experience.length>0){
    const list=document.getElementById('expList');
    d.experience.forEach(job=>{
      const card=document.createElement('div');card.className='exp-card';
      const bullets=(job.bullets||[]).map(b=>`<li contenteditable='true' spellcheck='true'>${b}</li>`).join('');
      card.innerHTML=`
        <div class="exp-header">
          <div><div class="exp-company">${job.company||''}</div><div class="exp-role">${job.role||''}</div></div>
          <div class="exp-right"><div class="exp-dates">${job.dates||''}</div><div class="exp-location">${job.location||''}</div></div>
        </div>
        ${bullets?`<ul class="exp-bullets">${bullets}</ul>`:''}`;
      list.appendChild(card);
    });
  } else { document.getElementById('expSection').style.display='none'; }

  // Education
  if(d.education && d.education.length>0){
    const eduList=document.getElementById('eduList');
    d.education.forEach(edu=>{
      const card=document.createElement('div');card.className='exp-card';
      card.innerHTML=`
        <div class="exp-header">
          <div><div class="exp-company">${edu.institution||''}</div><div class="exp-role">${edu.degree||''}</div></div>
          <div class="exp-right"><div class="exp-dates">${edu.dates||''}</div><div class="exp-location">${edu.location||''}</div></div>
        </div>`;
      eduList.appendChild(card);
    });
  } else { document.getElementById('eduSection').style.display='none'; }

  // Skills
  if(d.skills && d.skills.length>0){
    const wrap=document.getElementById('skillsList');
    d.skills.forEach(s=>{ const p=document.createElement('span');p.className='skill-pill';p.textContent=s;wrap.appendChild(p); });
  } else { document.getElementById('skillsSection').style.display='none'; }

  addMessage('assistant',`Hi! I'm ${d.name}'s AI assistant. Try asking me anything about their background — this is a live preview!`);
  if(!isEditMode) resetIdleTimer();
  wireEditableFields();
});

let idleTimer = null;
function resetIdleTimer(){
  clearTimeout(idleTimer);
  idleTimer = setTimeout(showPurchaseModal, 15000);
}
['click','keydown','mousemove','touchstart','scroll'].forEach(evt=>{
  document.addEventListener(evt, resetIdleTimer, {passive:true});
});

function switchTheme(name, el){
  document.documentElement.className = name === 'classic' ? '' : name;
  document.querySelectorAll('.ts-btn').forEach(b => b.classList.toggle('on', b === el));
  const raw = sessionStorage.getItem('ask_draft');
  if(raw){ const d=JSON.parse(raw); d.theme=name; delete d.avatar; sessionStorage.setItem('ask_draft',JSON.stringify(d)); }
}

function showPurchaseModal(){ document.getElementById('purchaseModal').classList.add('show'); }

function saveEdits(){ autoSave(); }

function handlePurchase(){
  saveEdits();
  const raw = sessionStorage.getItem('ask_draft');
  if(raw) localStorage.setItem('ask_purchase_data', raw);
  const plan = raw ? (JSON.parse(raw).plan || 'basic') : 'basic';
  const url = plan === 'custom' ? STRIPE_URL_CUSTOM : STRIPE_URL;
  window.location.href = url;
}

async function saveEdit(){
  if(!editSlug){ alert('No profile slug found.'); return; }
  saveEdits();
  const raw = sessionStorage.getItem('ask_draft');
  if(!raw){ alert('No profile data found.'); return; }
  const d = JSON.parse(raw);

  const btn = document.querySelector('#editBanner .btn-buy');
  btn.textContent = 'Saving...';
  btn.disabled = true;

  try {
    const res = await fetch(ASK_SERVER + '/update', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({slug: editSlug, data: d})
    });
    const result = await res.json();
    if(result.ok){
      sessionStorage.removeItem('ask_draft');
      sessionStorage.removeItem('ask_avatar');
      window.location.href = 'https://ask.menoslabs.com/' + editSlug;
    } else {
      btn.textContent = 'Save Changes →';
      btn.disabled = false;
      alert('Save failed: ' + (result.error || 'Unknown error'));
    }
  } catch(e){
    btn.textContent = 'Save Changes →';
    btn.disabled = false;
    alert('Connection error — please try again.');
  }
}

function toggleChat(){
  chatOpen=!chatOpen;
  document.getElementById('chat-panel').classList.toggle('open',chatOpen);
  if(chatOpen) setTimeout(()=>document.getElementById('chatInput').focus(),300);
}

function getInitials(){
  const n=document.getElementById('profileName').textContent;
  const p=n.split(' ').filter(Boolean);
  return(p.length>=2?p[0][0]+p[p.length-1][0]:p[0]?.[0]||'?').toUpperCase();
}

function addMessage(role,text){
  const wrap=document.getElementById('chatMessages');
  const div=document.createElement('div');div.className='cmsg '+role;
  const av=document.createElement('div');av.className='cmsg-avatar';
  if(role==='assistant'){if(avatarDataUrl)av.innerHTML=`<img src="${avatarDataUrl}" alt="avatar">`;else av.textContent=getInitials();}
  else{av.textContent='You';av.style.fontSize='0.5rem';av.style.color='var(--text3)';}
  const b=document.createElement('div');b.className='cmsg-bubble';b.textContent=text;
  div.appendChild(av);div.appendChild(b);wrap.appendChild(div);wrap.scrollTop=wrap.scrollHeight;
}

function showTyping(){
  const wrap=document.getElementById('chatMessages');
  const div=document.createElement('div');div.className='cmsg assistant';div.id='typingMsg';
  const av=document.createElement('div');av.className='cmsg-avatar';
  if(avatarDataUrl)av.innerHTML=`<img src="${avatarDataUrl}" alt="avatar">`;else av.textContent=getInitials();
  div.appendChild(av);
  const t=document.createElement('div');t.className='chat-typing';t.innerHTML='<span></span><span></span><span></span>';
  div.appendChild(t);wrap.appendChild(div);wrap.scrollTop=wrap.scrollHeight;
}

function askSugg(btn){document.getElementById('chatSuggRow').style.display='none';document.getElementById('chatInput').value=btn.textContent;sendChat();}
function chatKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat();}}

async function sendChat(){
  const input=document.getElementById('chatInput');
  const text=input.value.trim();
  if(!text||chatLoading)return;
  chatLoading=true;document.getElementById('chatSend').disabled=true;
  document.getElementById('chatSuggRow').style.display='none';
  input.value='';input.style.height='auto';
  addMessage('user',text);chatHistory.push({role:'user',content:text});showTyping();

  try{
    const res=await fetch(WORKER,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:400,system:systemPrompt,messages:chatHistory})});
    const data=await res.json();
    const reply=data.content?.[0]?.text||"I'm having connection issues.";
    document.getElementById('typingMsg')?.remove();
    addMessage('assistant',reply);chatHistory.push({role:'assistant',content:reply});
  }catch(e){document.getElementById('typingMsg')?.remove();addMessage('assistant','Connection issue — please try again.');}
  chatLoading=false;document.getElementById('chatSend').disabled=false;
}

function openFaq(){ document.getElementById('faqModal').classList.add('show'); document.body.style.overflow='hidden'; }
function closeFaq(){ document.getElementById('faqModal').classList.remove('show'); document.body.style.overflow=''; }
function toggleFaqModal(el){ el.parentElement.classList.toggle('open'); }
function switchFaqTab(name,btn){
  btn.closest('.faq-modal-a').querySelectorAll('.faq-modal-ptab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  btn.closest('.faq-modal-a').querySelectorAll('.faq-modal-panel').forEach(p=>p.classList.remove('on'));
  btn.closest('.faq-modal-a').querySelector('#faq-'+name).classList.add('on');
}

function gdprInit(){
  const c=localStorage.getItem('gdpr_consent');
  if(!c) setTimeout(()=>{const b=document.getElementById('gdpr-banner');if(b)b.classList.add('show');},800);
}
function gdprAccept(){
  localStorage.setItem('gdpr_consent','accepted');
  const b=document.getElementById('gdpr-banner');if(b)b.classList.remove('show');
}
function gdprDecline(){
  localStorage.setItem('gdpr_consent','declined');
  const b=document.getElementById('gdpr-banner');if(b)b.classList.remove('show');
}
gdprInit();
</script>
