*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--white:#FFFFFF;--off-white:#F7F6F3;--light:#EEECE8;--border:#E2DED8;--text1:#1A1A1A;--text2:#555550;--text3:#999990;--accent:#CCFF00;--accent-dark:#8AB300;--black:#111111;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--text1);min-height:100vh;display:flex;flex-direction:column;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.5rem 4rem;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:'Playfair Display',serif;font-weight:700;font-size:1.25rem;color:var(--text1);text-decoration:none;letter-spacing:-0.02em;}
.nav-logo span{display:inline-block;background:var(--accent);color:var(--black);padding:0 6px;margin-left:2px;font-style:italic;}
.nav-badge{font-size:0.7rem;color:var(--text3);letter-spacing:0.08em;background:var(--off-white);border:1px solid var(--border);padding:0.3rem 0.85rem;border-radius:100px;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:500;display:none;align-items:center;justify-content:center;backdrop-filter:blur(6px);}
.modal-overlay.show{display:flex;}
.purchase-card{background:var(--white);border:1px solid var(--border);border-radius:4px;padding:2.5rem;max-width:420px;width:90%;text-align:center;}
.purchase-eyebrow{font-size:0.7rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:var(--text3);margin-bottom:1rem;}
.purchase-title{font-family:'Playfair Display',serif;font-size:1.75rem;font-weight:700;letter-spacing:-0.03em;margin-bottom:0.5rem;}
.purchase-title span{font-style:italic;background:#CCFF00!important;color:#111111!important;padding:0 6px;}
.purchase-desc{font-size:0.85rem;color:var(--text2);font-weight:300;line-height:1.7;margin-bottom:1.75rem;}
.purchase-price{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;letter-spacing:-0.04em;margin-bottom:0.25rem;}
.purchase-price span{color:var(--accent-dark);}
.purchase-label{font-size:0.68rem;color:var(--text3);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1.75rem;}
.purchase-features{list-style:none;text-align:left;margin-bottom:2rem;display:flex;flex-direction:column;gap:0.5rem;}
.purchase-features li{font-size:0.82rem;color:var(--text2);font-weight:300;padding-left:1.25rem;position:relative;}
.purchase-features li::before{content:'✓';position:absolute;left:0;color:var(--accent-dark);font-weight:500;}
.btn-purchase{background:var(--black);color:var(--white);padding:0.9rem;font-size:0.85rem;font-weight:500;letter-spacing:0.05em;border:none;border-radius:2px;cursor:pointer;width:100%;margin-bottom:0.75rem;transition:all 0.2s;}
.btn-purchase:hover{background:var(--accent);color:var(--black);}
.btn-restart{font-size:0.72rem;color:var(--text3);background:none;border:none;cursor:pointer;text-decoration:underline;transition:color 0.2s;}
.btn-restart:hover{color:var(--text2);}
.profile-hero{background:var(--off-white);border-bottom:1px solid var(--border);padding:7rem 4rem 3.5rem;}
.profile-hero-inner{max-width:860px;margin:0 auto;display:flex;gap:2.5rem;align-items:flex-start;}
.profile-avatar{width:100px;height:100px;border-radius:50%;border:1px solid var(--border);background:var(--light);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;}
.profile-avatar img{width:100%;height:100%;object-fit:cover;}
.profile-avatar-initials{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:var(--text3);}
.profile-name{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:700;letter-spacing:-0.03em;line-height:1.1;margin-bottom:0.3rem;}
.profile-meta{font-size:0.72rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--text3);margin-bottom:1rem;}
.profile-bio{font-size:0.95rem;color:var(--text2);line-height:1.8;max-width:560px;font-weight:300;}
.profile-socials{display:flex;gap:0.75rem;margin-top:1.25rem;flex-wrap:wrap;}
.social-pill{font-size:0.7rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;padding:0.35rem 1rem;background:var(--white);border:1px solid var(--border);color:var(--text2);text-decoration:none;border-radius:100px;transition:all 0.2s;}
.social-pill:hover{border-color:var(--accent-dark);color:var(--text1);}
.main-content{max-width:860px;margin:0 auto;width:100%;padding:3.5rem 4rem 8rem;flex:1;}
.section-tag{font-size:0.65rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:var(--text3);margin-bottom:0.75rem;}
.section-title{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:1.5rem;}
.exp-list{display:flex;flex-direction:column;gap:1rem;margin-bottom:3.5rem;}
.exp-card{background:var(--white);border:1px solid var(--border);border-radius:4px;padding:1.75rem 2rem;position:relative;overflow:hidden;transition:all 0.25s;}
.exp-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:transparent;transition:background 0.25s;}
.exp-card:hover{border-color:#D0D0C8;transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.06);}
.exp-card:hover::before{background:var(--accent);}
.exp-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.85rem;flex-wrap:wrap;gap:0.5rem;}
.exp-company{font-size:0.65rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent-dark);margin-bottom:0.25rem;}
.exp-role{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:600;letter-spacing:-0.01em;color:var(--text1);}
.exp-right{text-align:right;flex-shrink:0;}
.exp-dates{font-size:0.75rem;color:var(--text3);}
.exp-location{font-size:0.72rem;color:var(--text3);margin-top:0.1rem;}
.exp-bullets{list-style:none;margin-top:0.75rem;}
.exp-bullets li{font-size:0.85rem;color:var(--text2);line-height:1.7;padding-left:1.25rem;position:relative;margin-bottom:0.35rem;font-weight:300;}
.exp-bullets li::before{content:'›';position:absolute;left:0;color:var(--accent-dark);font-size:1rem;line-height:1.6;}
.skills-wrap{margin-bottom:3.5rem;}
.skills-pills{display:flex;flex-wrap:wrap;gap:0.5rem;}
.skill-pill{font-size:0.78rem;font-weight:400;padding:0.4rem 0.9rem;background:var(--off-white);border:1px solid var(--border);color:var(--text2);border-radius:100px;transition:all 0.2s;}
.skill-pill:hover{background:var(--light);border-color:#C8C8C0;color:var(--text1);}
.purchase-banner{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%);z-index:200;background:var(--white);border:1px solid var(--border);border-radius:4px;padding:1rem 1.5rem;display:flex;align-items:center;gap:1.5rem;box-shadow:0 8px 32px rgba(0,0,0,0.12);white-space:nowrap;}
.banner-text{font-size:0.82rem;color:var(--text2);font-weight:300;}
.banner-text strong{color:var(--text1);font-weight:500;}
.btn-buy{background:var(--black);color:var(--white);padding:0.65rem 1.5rem;font-size:0.8rem;font-weight:500;letter-spacing:0.05em;border:none;border-radius:2px;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.btn-buy:hover{background:var(--accent);color:var(--black);}
#chat-toggle{position:fixed;bottom:2rem;right:2rem;z-index:300;background:var(--black);color:var(--white);border:none;border-radius:50px;padding:0.85rem 1.75rem;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:0.6rem;box-shadow:0 8px 30px rgba(0,0,0,0.2);transition:all 0.2s;}
#chat-toggle:hover{background:var(--accent);color:var(--black);}
.chat-toggle-dot{width:8px;height:8px;background:#22c55e;border-radius:50%;animation:pulseDot 2s ease-in-out infinite;}
@keyframes pulseDot{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(1.3);opacity:0.7;}}
#chat-panel{position:fixed;bottom:5.5rem;right:2rem;z-index:299;width:360px;height:500px;background:var(--white);border:1px solid var(--border);border-radius:8px;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,0.12);transform:scale(0.95) translateY(10px);opacity:0;pointer-events:none;transition:all 0.25s ease;overflow:hidden;}
#chat-panel.open{transform:scale(1) translateY(0);opacity:1;pointer-events:auto;}
.chat-panel-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;background:var(--off-white);}
.chat-panel-name{font-family:'Playfair Display',serif;font-size:1rem;font-weight:600;}
.chat-panel-sub{font-size:0.65rem;color:var(--text3);letter-spacing:0.08em;margin-top:1px;}
.chat-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:1.1rem;padding:0.2rem;transition:color 0.2s;}
.chat-close:hover{color:var(--text1);}
.chat-messages{flex:1;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:0.75rem;scroll-behavior:smooth;}
.chat-messages::-webkit-scrollbar{width:3px;}
