.cmsg{display:flex;gap:0.5rem;}
.cmsg.user{flex-direction:row-reverse;}
.cmsg-avatar{width:26px;height:26px;border-radius:50%;border:1px solid var(--border);background:var(--light);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:0.55rem;font-weight:700;color:var(--text3);flex-shrink:0;margin-top:2px;overflow:hidden;}
.cmsg-avatar img{width:100%;height:100%;object-fit:cover;}
.cmsg-bubble{padding:0.65rem 0.9rem;border-radius:2px;font-size:0.8rem;line-height:1.6;max-width:85%;}
.cmsg.assistant .cmsg-bubble{background:var(--off-white);border:1px solid var(--border);color:var(--text1);}
.cmsg.user .cmsg-bubble{background:var(--black);color:var(--white);}
.chat-typing{display:flex;gap:4px;align-items:center;padding:0.65rem 0.9rem;background:var(--off-white);border:1px solid var(--border);width:fit-content;border-radius:2px;}
.chat-typing span{width:5px;height:5px;background:var(--accent-dark);border-radius:50%;animation:typingBounce 1.2s ease-in-out infinite;}
.chat-typing span:nth-child(2){animation-delay:0.2s;}
.chat-typing span:nth-child(3){animation-delay:0.4s;}
@keyframes typingBounce{0%,60%,100%{transform:translateY(0);opacity:0.4;}30%{transform:translateY(-4px);opacity:1;}}
.chat-sugg-row{padding:0.5rem 0.75rem;display:flex;gap:0.4rem;flex-wrap:wrap;border-bottom:1px solid var(--border);flex-shrink:0;}
.chat-sugg{font-size:0.62rem;padding:0.3rem 0.7rem;background:var(--off-white);border:1px solid var(--border);color:var(--text2);border-radius:100px;cursor:pointer;transition:all 0.2s;}
html.dark button.chat-sugg{background:#1e1e1e!important;border:1px solid rgba(204,255,0,0.4)!important;color:#CCFF00!important;}
.chat-sugg:hover{border-color:var(--accent-dark);color:var(--text1);}
.chat-input-row{padding:0.75rem;border-top:1px solid var(--border);display:flex;gap:0.5rem;flex-shrink:0;}
.chat-input{flex:1;font-family:'DM Sans',sans-serif;font-size:0.8rem;background:var(--off-white);border:1px solid var(--border);color:var(--text1);padding:0.55rem 0.85rem;outline:none;border-radius:2px;resize:none;transition:border-color 0.2s;}
.chat-input:focus{border-color:var(--accent-dark);}
.chat-input::placeholder{color:var(--text3);}
.chat-send{width:34px;height:34px;background:var(--black);border:none;border-radius:2px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.2s;flex-shrink:0;}
.chat-send:hover{background:var(--accent);}
.chat-send:disabled{opacity:0.3;cursor:not-allowed;}
[contenteditable]{outline:none;cursor:text;}
[contenteditable]:hover{background:rgba(204,255,0,0.06);border-radius:2px;}
[contenteditable]:focus{background:rgba(204,255,0,0.1);border-radius:2px;box-shadow:0 0 0 1px var(--accent-dark);}
.edit-hint{font-size:0.62rem;color:var(--text3);letter-spacing:0.1em;text-transform:uppercase;margin-top:0.5rem;display:flex;align-items:center;gap:0.35rem;}
.edit-hint::before{content:'✎';font-size:0.7rem;}
footer{background:var(--black);padding:2rem 4rem;display:flex;align-items:center;justify-content:space-between;margin-top:auto;}
.footer-logo{font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;color:rgba(255,255,255,0.4);text-decoration:none;}
.footer-logo span{background:var(--accent);color:var(--black);padding:0 5px;font-style:italic;}
.footer-copy{font-size:0.72rem;color:rgba(255,255,255,0.25);letter-spacing:0.05em;}
#theme-switcher{position:fixed;top:4.5rem;left:50%;transform:translateX(-50%);z-index:90;display:flex;gap:0.4rem;background:rgba(255,255,255,0.95);border:1px solid var(--border);border-radius:50px;padding:0.35rem 0.5rem;backdrop-filter:blur(8px);box-shadow:0 2px 12px rgba(0,0,0,0.08);}
.ts-btn{font-size:0.62rem;font-weight:500;letter-spacing:0.08em;padding:0.3rem 0.85rem;border:1px solid transparent;border-radius:50px;cursor:pointer;background:none;color:var(--text2);transition:all 0.2s;}
.ts-btn:hover{background:var(--off-white);color:var(--text1);}
.ts-btn.on{background:var(--black);color:var(--white);border-color:var(--black);}
html.dark .nav-badge{background:#CCFF00!important;color:#111111!important;border-color:#CCFF00;}
html.bold .nav-badge{background:#000!important;color:#fff!important;border-color:#000;}
html.soft .nav-badge{background:#D48B3A!important;color:#fff!important;border-color:#D48B3A;}
