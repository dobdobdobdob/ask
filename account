// ── EMBED / MY PAGE ──
const INSTRUCTIONS = {
  wix:{chat:['In your Wix editor, click <strong>Add Elements</strong> in the left sidebar','Select <strong>Embed Code</strong> → <strong>HTML iframe</strong>','Paste the code below into the HTML box','Click <strong>Apply</strong> and position the element','Publish your site'],full:['In your Wix editor click <strong>Add Elements</strong> → <strong>Embed Code</strong>','Select <strong>HTML iframe</strong>','Paste the iframe code below and click <strong>Apply</strong>','Resize the element to fill the section','Publish your site']},
  squarespace:{chat:['Go to the page where you want the chat button','Click <strong>Edit</strong> → hover over a section → click <strong>+</strong>','Select <strong>Code</strong> block','Paste the code below and click <strong>Apply</strong>','Save and publish'],full:['Go to your page and click <strong>Edit</strong>','Add a <strong>Code</strong> block where you want the profile','Paste the iframe code below','Adjust the height as needed and publish']},
  wordpress:{chat:['In WordPress go to <strong>Appearance → Theme Editor</strong>','Open your theme\'s <strong>footer.php</strong> file','Paste the code just before the <strong>&lt;/body&gt;</strong> tag','Save — the chat button will appear on every page'],full:['Create or edit a page in WordPress','Click <strong>+</strong> to add a block → search for <strong>Custom HTML</strong>','Paste the iframe code below','Save and preview']},
  any:{chat:['Open your website\'s HTML file or template','Paste the code below just before the closing <strong>&lt;/body&gt;</strong> tag','Save and upload — the chat button will appear on every page'],full:['Open the HTML file where you want the profile','Paste the iframe code below where you want it to appear','Save and upload']}
};
function getEmbedCode(type){
  if(type==='chat') return '<'+'script src="https://ask.menoslabs.com/embed.js" data-slug="'+currentSlug+'"><'+'/script>';
  return '<'+'iframe src="'+shareUrl+'" width="100%" height="700" frameborder="0" style="border:none;border-radius:4px;" title="Ask '+currentSlug+'"><'+'/iframe>';
}
function escapeHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function renderPlatformContent(){
  if(!currentSlug){ return; }
  const steps = INSTRUCTIONS[currentPlatform][embedType];
  rawEmbedCode = getEmbedCode(embedType);
  const stepsHtml = steps.map((s,i)=>'<div class="step-item"><div class="step-circle">'+(i+1)+'</div><div class="step-text">'+s+'</div></div>').join('');
  document.getElementById('platform-content').innerHTML =
    '<div style="margin-bottom:1rem;">'+stepsHtml+'</div>'+
    '<div class="code-block">'+escapeHtml(rawEmbedCode)+'</div>'+
    '<button class="copy-btn" onclick="copyEmbed()" style="margin-bottom:0.5rem;">Copy Code</button>';
}
function selectEmbed(type){ embedType=type; document.getElementById('opt-chat').classList.toggle('active',type==='chat'); document.getElementById('opt-full').classList.toggle('active',type==='full'); renderPlatformContent(); }
function selectPlatform(p,btn){ currentPlatform=p; document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on')); btn.classList.add('on'); renderPlatformContent(); }
function copyUrl(){ navigator.clipboard.writeText(shareUrl).then(()=>{ const b=document.getElementById('copyUrlBtn'); b.textContent='Copied!'; b.classList.add('copied'); setTimeout(()=>{b.textContent='Copy';b.classList.remove('copied');},2000); }); }
function copyEmbed(){ navigator.clipboard.writeText(rawEmbedCode).then(()=>{ const b=document.querySelector('#platform-content .copy-btn'); if(b){b.textContent='Copied!';b.classList.add('copied');setTimeout(()=>{b.textContent='Copy Code';b.classList.remove('copied');},2000);} }); }

// ── THEME & FONT ──
function pickTheme(name,el){ selectedTheme=name; document.querySelectorAll('.theme-card').forEach(c=>c.classList.toggle('on',c===el)); }
function pickFont(name,el){ selectedFont=name; document.querySelectorAll('.font-card').forEach(c=>c.classList.toggle('on',c===el)); }

// ── AVATAR ──
document.getElementById('avatarInput').addEventListener('change', function(){
  const file = this.files[0]; if(!file) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = 200; canvas.height = 200;
      const ctx = canvas.getContext('2d');
      const size = Math.min(img.width, img.height);
      const sx = (img.width-size)/2, sy = (img.height-size)/2;
      ctx.drawImage(img, sx, sy, size, size, 0, 0, 200, 200);
      avatarDataUrl = canvas.toDataURL('image/jpeg', 0.8);
      document.getElementById('avatarCircle').innerHTML = `<img src="${avatarDataUrl}" alt="avatar"><div class="avatar-cam"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>`;
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(file);
});

function updateInitials(){
  const n = document.getElementById('iName').value.trim();
  const p = n.split(' ').filter(Boolean);
  const i = p.length>=2 ? p[0][0]+p[p.length-1][0] : p[0]?.[0]||'?';
  document.getElementById('avatarInitials').textContent = i.toUpperCase();
}

// ── SAVE INFO (no regen) ──
async function saveInfo(){
  const name = document.getElementById('iName').value.trim();
  const title = document.getElementById('iTitle').value.trim();
