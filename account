// ── REGENERATE ──
async function generateEdit(){
  const name = document.getElementById('iName').value.trim().replace(/[^a-zA-Z0-9\s\-]/g,'').trim();
  const title = document.getElementById('iTitle').value.trim();
  const city = document.getElementById('iCity').value.trim();
  const email = document.getElementById('iEmail').value.trim();
  const rawResume = document.getElementById('iResume').value.trim();
  const resume = rawResume
    .replace(/\+?[\d][\d\s\-().]{7,}[\d]/g,'[phone removed]')
    .replace(/\d+\s+[A-Za-z0-9\s,\.]+(?:Street|St|Avenue|Ave|Road|Rd|Boulevard|Blvd|Drive|Dr|Lane|Ln|Court|Ct|Way|Place|Pl|Circle|Cir|Trail|Tr|Parkway|Pkwy|Highway|Hwy)[^\n]*/gi,'[address removed]')
    .replace(/\b[A-Za-z\s]+,\s*[A-Z]{2}\s+\d{5}(?:-\d{4})?\b/g,'[address removed]')
    .trim();
  if(!name){ alert('Please enter your name.'); return; }
  if(!resume){ alert('Please paste your resume text above.'); return; }
  if(resume.length < 100){ alert('Resume seems too short — paste your full resume for best results.'); return; }
  const socials = {
    linkedin: document.getElementById('sLinkedIn').value.trim(),
    portfolio: document.getElementById('sPortfolio').value.trim(),
    github: document.getElementById('sGithub').value.trim(),
    twitter: document.getElementById('sTwitter').value.trim(),
    tiktok: document.getElementById('sTiktok').value.trim(),
    instagram: document.getElementById('sInstagram').value.trim(),
  };
  document.getElementById('editActions').style.display='none';
  document.getElementById('processing').style.display='block';
  document.getElementById('saveSuccess').style.display='none';
  const texts = ['Reading your resume...','Extracting experience...','Building your assistant...','Almost ready...'];
  let gi=0;
  const iv = setInterval(()=>{ gi=(gi+1)%texts.length; document.getElementById('procText').textContent=texts[gi]; }, 1800);
  try {
    const res = await fetch(WORKER, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:8000,
        messages:[{role:'user', content:
`You are parsing a resume. CRITICAL RULES:
- Only use information explicitly stated in the resume text below
- Do NOT invent, assume, or hallucinate any companies, roles, dates, or achievements
- If the resume text looks garbled or unreadable, return an error field instead
- Only include companies and roles that are clearly named in the text
- Do NOT include any physical addresses or phone numbers in any field

Resume for ${name}:
---
${resume}
---

Respond with ONLY a valid JSON object (no markdown, no backticks):
{
  "bio": "2-3 sentence bio using ONLY facts from the resume above. Third person.",
  "experience": [{"company":"EXACT company name from resume only","role":"EXACT job title from resume only","dates":"dates as written in resume","location":"city and state only, no street addresses","bullets":["achievement or responsibility exactly as described in resume"]}],
  "education": [{"institution":"EXACT school name from resume only","degree":"degree and field as written in resume","dates":"dates as written in resume","location":"city and state only if mentioned"}],
  "skills": ["only skills explicitly mentioned in the resume"],
  "systemPrompt": "You are a professional AI assistant for ${name}. Only discuss what is in their resume. If asked about something not in their background, say you don't have that information. Background from resume: [paste all key facts from the resume here]"
}`
        }]
      })
    });
    const data = await res.json();
    const raw = data.content?.[0]?.text || '{}';
    let parsed;
    try { parsed = JSON.parse(raw); }
    catch(e){ const m=raw.match(/\{[\s\S]*\}/); parsed=m?JSON.parse(m[0]):{bio:'',experience:[],education:[],skills:[],systemPrompt:`You are an AI assistant for ${name}.`}; }
    clearInterval(iv);
    let existing = {};
    try{ const er=await fetch(`${ASK_SERVER}/${currentSlug}`); existing=await er.json(); }catch(e){}
    const updated = {
      ...existing, name, title, city, email, socials,
      theme: selectedTheme, font: selectedFont,
      meta: [title,city].filter(Boolean).join(' · '),
      bio: parsed.bio, experience: parsed.experience||[], education: parsed.education||[],
      skills: parsed.skills||[], systemPrompt: parsed.systemPrompt, resume,
      ...(avatarDataUrl ? {avatar: avatarDataUrl} : {})
    };
    await fetch(`${ASK_SERVER}/update`, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ slug: currentSlug, data: updated })
    });
    document.getElementById('processing').style.display='none';
    document.getElementById('editActions').style.display='block';
    showSaveSuccess('Profile regenerated and saved. <a href="'+shareUrl+'" target="_blank" style="color:var(--accent-dark);">View your page →</a>');
  } catch(err){
    clearInterval(iv);
    document.getElementById('procText').textContent='Something went wrong. Please try again.';
    document.getElementById('processing').style.display='none';
    document.getElementById('editActions').style.display='block';
  }
}

function showSaveSuccess(msg){
