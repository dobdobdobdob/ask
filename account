<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--white:#FFFFFF;--off-white:#F7F6F3;--light:#EEECE8;--border:#E2DED8;--text1:#1A1A1A;--text2:#555550;--text3:#999990;--accent:#CCFF00;--accent-dark:#8AB300;--black:#111111;}
body{font-family:'DM Sans',sans-serif;background:var(--off-white);color:var(--text1);min-height:100vh;display:flex;flex-direction:column;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.5rem 4rem;display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:'Playfair Display',serif;font-weight:700;font-size:1.25rem;color:var(--text1);text-decoration:none;letter-spacing:-0.02em;}
.nav-logo span{display:inline-block;background:var(--accent);color:var(--black);padding:0 6px;margin-left:2px;font-style:italic;}
.nav-back{font-size:0.78rem;color:var(--text3);text-decoration:none;transition:color 0.2s;}
.nav-back:hover{color:var(--text1);}

/* PAGE */
.page{max-width:680px;margin:0 auto;padding:7rem 2rem 4rem;flex:1;}
.page-eyebrow{font-size:0.72rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:var(--text3);margin-bottom:0.75rem;}
.page-title{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;letter-spacing:-0.03em;margin-bottom:0.5rem;}
.page-sub{font-size:0.9rem;color:var(--text2);font-weight:300;line-height:1.7;margin-bottom:2rem;}

/* AUTH STEPS */
.card{background:var(--white);border:1px solid var(--border);border-radius:4px;padding:2.5rem;}
.step{display:none;}
.step.active{display:block;}
.flabel{font-size:0.62rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;color:var(--text3);display:block;margin-bottom:0.4rem;}
.finput{font-family:'DM Sans',sans-serif;font-size:0.88rem;font-weight:300;background:var(--off-white);border:1px solid var(--border);color:var(--text1);padding:0.7rem 1rem;outline:none;transition:border-color 0.2s;border-radius:2px;width:100%;}
.finput:focus{border-color:var(--accent-dark);}
.finput::placeholder{color:var(--text3);}
.field{margin-bottom:1rem;}
.btn{background:var(--black);color:var(--white);padding:0.9rem;font-size:0.85rem;font-weight:500;letter-spacing:0.05em;border:none;border-radius:2px;cursor:pointer;width:100%;margin-top:0.5rem;transition:all 0.2s;display:block;text-align:center;}
.btn:hover{background:var(--accent);color:var(--black);}
.btn:disabled{opacity:0.4;cursor:not-allowed;}
.btn-secondary{background:none;color:var(--text3);border:1px solid var(--border);padding:0.7rem;font-size:0.78rem;font-weight:400;border-radius:2px;cursor:pointer;width:100%;margin-top:0.5rem;transition:all 0.2s;}
.btn-secondary:hover{color:var(--text1);border-color:var(--text2);}
.status{font-size:0.78rem;margin-top:0.5rem;min-height:1.2em;}
.status.ok{color:var(--accent-dark);}
.status.err{color:#e05c5c;}
.profile-confirm{background:var(--off-white);border:1px solid var(--border);border-radius:2px;padding:1rem;margin:1rem 0;}
.profile-confirm-name{font-weight:500;font-size:0.95rem;margin-bottom:0.2rem;}
.profile-confirm-meta{font-size:0.78rem;color:var(--text3);}
.code-input{font-family:'DM Sans',monospace;font-size:1.5rem;font-weight:500;letter-spacing:0.4em;text-align:center;text-transform:uppercase;}
.masked-email{font-size:0.82rem;color:var(--text2);margin:0.75rem 0;font-weight:300;}
.form-section-title{font-size:0.65rem;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;color:var(--text3);margin-bottom:1rem;padding-bottom:0.75rem;border-bottom:1px solid var(--border);}

/* TABS */
.tab-nav{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:2rem;}
.tab-btn{font-size:0.82rem;font-weight:500;padding:0.75rem 1.5rem;background:none;border:none;border-bottom:2px solid transparent;color:var(--text3);cursor:pointer;transition:all 0.2s;margin-bottom:-2px;font-family:'DM Sans',sans-serif;}
.tab-btn:hover{color:var(--text1);}
.tab-btn.on{color:var(--text1);border-bottom-color:var(--black);}
.tab-panel{display:none;}
.tab-panel.on{display:block;}

/* MY PAGE TAB */
.url-row{display:flex;align-items:center;gap:0.5rem;background:var(--off-white);border:1px solid var(--border);border-radius:2px;padding:0.75rem 1rem;margin-bottom:1rem;}
.url-text{flex:1;font-size:0.85rem;color:var(--text1);font-family:'DM Sans',monospace;word-break:break-all;}
.copy-btn{font-size:0.68rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;padding:0.4rem 1rem;background:var(--black);color:var(--white);border:none;border-radius:2px;cursor:pointer;transition:all 0.2s;white-space:nowrap;flex-shrink:0;}
.copy-btn:hover{background:var(--accent);color:var(--black);}
.copy-btn.copied{background:var(--accent-dark);color:var(--white);}
.view-btn{display:block;text-align:center;background:var(--black);color:var(--white);padding:0.85rem;font-size:0.85rem;font-weight:500;letter-spacing:0.05em;border:none;border-radius:2px;cursor:pointer;transition:all 0.2s;text-decoration:none;margin-bottom:1.5rem;}
.view-btn:hover{background:var(--accent);color:var(--black);}
.embed-options{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;}
.embed-option{border:1px solid var(--border);border-radius:4px;padding:1.25rem;cursor:pointer;transition:all 0.2s;}
.embed-option:hover{border-color:var(--accent-dark);}
.embed-option.active{border-color:var(--accent-dark);background:var(--off-white);}
.embed-option-title{font-size:0.88rem;font-weight:500;margin-bottom:0.2rem;}
.embed-option-desc{font-size:0.75rem;color:var(--text2);font-weight:300;line-height:1.5;}
.platform-tabs{display:flex;gap:0;margin-bottom:1.25rem;border-bottom:1px solid var(--border);}
.ptab{font-size:0.72rem;font-weight:500;letter-spacing:0.08em;padding:0.6rem 1.1rem;background:none;border:none;border-bottom:2px solid transparent;color:var(--text3);cursor:pointer;transition:all 0.2s;margin-bottom:-1px;}
.ptab.on{color:var(--text1);border-bottom-color:var(--black);}
.step-item{display:flex;gap:0.85rem;align-items:flex-start;margin-bottom:0.6rem;}
.step-circle{width:22px;height:22px;background:var(--black);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.62rem;font-weight:700;color:var(--white);flex-shrink:0;margin-top:1px;}
.step-text{font-size:0.82rem;color:var(--text2);line-height:1.6;font-weight:300;}
.step-text strong{color:var(--text1);font-weight:500;}
.code-block{background:var(--off-white);border:1px solid var(--border);border-radius:2px;padding:1rem;font-family:'DM Sans',monospace;font-size:0.75rem;color:var(--text1);word-break:break-all;line-height:1.6;margin-bottom:0.75rem;white-space:pre-wrap;}

/* EDIT TAB */
.fields-2{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1rem;}
.socials-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1rem;}
.social-field{display:flex;align-items:center;gap:0.5rem;background:var(--off-white);border:1px solid var(--border);border-radius:2px;padding:0.6rem 0.9rem;transition:border-color 0.2s;}
.social-field:focus-within{border-color:var(--accent-dark);}
.social-icon{font-size:0.85rem;flex-shrink:0;width:18px;text-align:center;color:var(--text3);}
.social-input{flex:1;font-family:'DM Sans',sans-serif;font-size:0.8rem;font-weight:300;background:none;border:none;color:var(--text1);outline:none;}
.social-input::placeholder{color:var(--text3);}
.avatar-row{display:flex;align-items:center;gap:1.5rem;margin-bottom:1.5rem;}
.avatar-wrap{display:flex;flex-direction:column;align-items:center;gap:0.4rem;}
.avatar-circle{width:72px;height:72px;border-radius:50%;border:1px solid var(--border);background:var(--off-white);display:flex;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;flex-shrink:0;transition:border-color 0.2s;position:relative;}
.avatar-circle:hover{border-color:var(--accent-dark);}
.avatar-circle:hover .avatar-cam{opacity:1;}
.avatar-circle img{width:100%;height:100%;object-fit:cover;}
.avatar-initials{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--text3);}
.avatar-cam{position:absolute;inset:0;background:rgba(0,0,0,0.35);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s;}
.avatar-hint{font-size:0.62rem;color:var(--text3);letter-spacing:0.08em;}
.avatar-name-col{flex:1;display:flex;flex-direction:column;gap:0.75rem;}
.theme-picker{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1.5rem;}
.theme-card{border:1px solid var(--border);border-radius:4px;padding:0.75rem;cursor:pointer;transition:all 0.2s;}
.theme-card:hover{border-color:var(--accent-dark);}
.theme-card.on{border-color:var(--accent-dark);background:var(--off-white);box-shadow:0 0 0 1px var(--accent-dark);}
.theme-preview{width:100%;height:40px;border-radius:3px;padding:6px;display:flex;flex-direction:column;justify-content:center;margin-bottom:0.4rem;overflow:hidden;}
.theme-label{font-size:0.75rem;font-weight:500;color:var(--text1);margin-bottom:1px;}
.theme-desc{font-size:0.62rem;color:var(--text3);}
.font-picker{display:grid;grid-template-columns:repeat(3,1fr);gap:0.65rem;margin-bottom:1.5rem;}
.font-card{border:1px solid var(--border);border-radius:4px;padding:0.85rem 1rem;cursor:pointer;transition:all 0.2s;text-align:center;}
.font-card:hover{border-color:var(--accent-dark);}
.font-card.on{border-color:var(--accent-dark);background:var(--off-white);box-shadow:0 0 0 1px var(--accent-dark);}
.font-card-name{font-size:1rem;font-weight:500;color:var(--text1);margin-bottom:2px;line-height:1.2;}
.font-card-label{font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);}
.processing{display:none;text-align:center;padding:2rem 0;}
.proc-dots{display:flex;gap:6px;justify-content:center;margin-bottom:1rem;}
.proc-dot{width:8px;height:8px;background:var(--accent-dark);border-radius:50%;animation:dotPulse 1.4s ease-in-out infinite;}
.proc-dot:nth-child(2){animation-delay:0.2s;}
.proc-dot:nth-child(3){animation-delay:0.4s;}
@keyframes dotPulse{0%,80%,100%{transform:scale(0.6);opacity:0.3;}40%{transform:scale(1);opacity:1;}}
.proc-text{font-size:0.82rem;color:var(--text2);letter-spacing:0.05em;}
.edit-badge{display:inline-flex;align-items:center;gap:0.4rem;background:rgba(138,179,0,0.1);border:1px solid rgba(138,179,0,0.3);border-radius:2px;padding:0.4rem 0.85rem;font-size:0.72rem;color:var(--accent-dark);font-weight:500;letter-spacing:0.05em;margin-bottom:1.5rem;}

/* FOOTER */
footer{background:var(--black);padding:1.5rem 4rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-top:auto;}
.footer-logo{font-family:'Playfair Display',serif;font-weight:700;font-size:1rem;color:rgba(255,255,255,0.4);text-decoration:none;}
.footer-logo span{background:var(--accent);color:var(--black);padding:0 5px;font-style:italic;}
.footer-copy{font-size:0.72rem;color:rgba(255,255,255,0.25);letter-spacing:0.03em;}

/* GDPR */
#gdpr-banner{position:fixed;bottom:0;left:0;right:0;z-index:999;background:#111;border-top:1px solid rgba(255,255,255,0.1);padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;transform:translateY(100%);transition:transform 0.3s ease;}
#gdpr-banner.show{transform:translateY(0);}
.gdpr-text{font-size:0.78rem;color:rgba(255,255,255,0.6);line-height:1.5;font-weight:300;}
.gdpr-btns{display:flex;gap:0.5rem;flex-shrink:0;}
.gdpr-accept{font-size:0.72rem;font-weight:500;padding:0.45rem 1.1rem;background:#CCFF00;color:#000;border:none;border-radius:2px;cursor:pointer;}
.gdpr-decline{font-size:0.72rem;font-weight:500;padding:0.45rem 1.1rem;background:none;color:rgba(255,255,255,0.4);border:1px solid rgba(255,255,255,0.15);border-radius:2px;cursor:pointer;}
#avatarInput{display:none;}

@media(max-width:640px){
  nav{padding:1.25rem 1.5rem;}
  .card{padding:1.75rem;}
  .fields-2,.socials-grid,.embed-options,.theme-picker{grid-template-columns:1fr;}
  .font-picker{grid-template-columns:repeat(2,1fr);}
  footer{flex-direction:column;gap:0.5rem;padding:1.25rem 1.5rem;text-align:center;}
}
</style>
</head>
<body>
<input type="file" id="avatarInput" accept="image/*">
<input type="file" id="pdfInput" accept=".pdf" style="display:none">

<nav>
  <a href="/" class="nav-logo">Ask<span>.</span></a>
  <a href="/" class="nav-back">← Back</a>
</nav>

<div class="page">
  <p class="page-eyebrow">Your Account</p>
  <h1 class="page-title">Manage My Account.</h1>
  <p class="page-sub">Enter your username and verify your identity to manage your Ask page.</p>

  <!-- STEP 1: Username -->
  <div class="card">
    <div class="step active" id="step1">
      <p class="form-section-title">Step 1 — Your Username</p>
      <div class="field">
        <label class="flabel">Username</label>
        <input class="finput" id="iSlug" type="text" placeholder="janesmith" oninput="onSlugInput()">
        <div class="status" id="slugStatus"></div>
      </div>
      <div id="profileConfirm" style="display:none">
        <div class="profile-confirm">
          <div class="profile-confirm-name" id="confirmName"></div>
          <div class="profile-confirm-meta" id="confirmMeta"></div>
        </div>
      </div>
      <button class="btn" id="btnStep1" onclick="checkProfile()" disabled>Look Up My Profile →</button>
    </div>

    <!-- STEP 2: Request code -->
    <div class="step" id="step2">
      <p class="form-section-title">Step 2 — Verify Your Identity</p>
      <p style="font-size:0.88rem;color:var(--text2);font-weight:300;line-height:1.7;margin-bottom:1rem;">We'll send a 6-digit verification code to the email address on your account.</p>
      <div class="masked-email" id="maskedEmailDisplay"></div>
      <button class="btn" id="btnRequestCode" onclick="requestCode()">Send Verification Code →</button>
      <div class="status" id="codeRequestStatus"></div>
      <button class="btn-secondary" onclick="goToStep(1)">← Use a different username</button>
    </div>

    <!-- STEP 3: Enter code -->
    <div class="step" id="step3">
      <p class="form-section-title">Step 3 — Enter Your Code</p>
      <div class="masked-email" id="maskedEmailDisplay2"></div>
      <div class="field" style="margin-top:1rem;">
        <label class="flabel">Verification Code</label>
        <input class="finput code-input" id="iCode" type="text" maxlength="6" placeholder="ABC123" oninput="onCodeInput()">
        <div class="status" id="codeStatus"></div>
      </div>
      <button class="btn" id="btnVerify" onclick="verifyCode()" disabled>Verify & Manage My Account →</button>
      <button class="btn-secondary" id="btnResend" onclick="requestCode()">Resend code</button>
      <div class="status" id="resendStatus"></div>
    </div>

    <!-- STEP 4: Tabbed account management -->
    <div class="step" id="step4">
      <div class="edit-badge">✓ Verified — ask.menoslabs.com/<span id="editSlugBadge"></span></div>

      <div class="tab-nav">
        <button class="tab-btn on" onclick="switchTab('mypage', this)">My Page</button>
        <button class="tab-btn" onclick="switchTab('edit', this)">Edit Profile</button>
        <button class="tab-btn" onclick="switchTab('customdomain', this)">Custom Domain</button>
      </div>

      <!-- MY PAGE TAB -->
      <div class="tab-panel on" id="tab-mypage">
        <p class="form-section-title">Your Shareable Page</p>
        <div class="url-row">
          <div class="url-text" id="shareUrl">—</div>
          <button class="copy-btn" id="copyUrlBtn" onclick="copyUrl()">Copy</button>
        </div>
        <a class="view-btn" id="viewPageBtn" href="#" target="_blank">View My Page →</a>

        <p class="form-section-title" style="margin-top:1.5rem;">Embed on Your Website</p>
        <div class="embed-options">
          <div class="embed-option active" id="opt-chat" onclick="selectEmbed('chat')">
            <div class="embed-option-title">Chat Button Only</div>
            <div class="embed-option-desc">Floating button on any page. Best for portfolios and personal sites.</div>
          </div>
          <div class="embed-option" id="opt-full" onclick="selectEmbed('full')">
            <div class="embed-option-title">Full Profile Page</div>
            <div class="embed-option-desc">Embed your complete profile with experience, skills, and chat.</div>
          </div>
        </div>
        <div class="platform-tabs">
          <button class="ptab on" onclick="selectPlatform('wix',this)">Wix</button>
          <button class="ptab" onclick="selectPlatform('squarespace',this)">Squarespace</button>
          <button class="ptab" onclick="selectPlatform('wordpress',this)">WordPress</button>
          <button class="ptab" onclick="selectPlatform('any',this)">Any Site</button>
        </div>
        <div id="platform-content"></div>
      </div>

      <!-- EDIT TAB -->
      <div class="tab-panel" id="tab-edit">
        <p class="form-section-title">Profile Info</p>
        <div class="avatar-row">
          <div class="avatar-wrap">
            <div class="avatar-circle" id="avatarCircle" onclick="document.getElementById('avatarInput').click()">
              <div class="avatar-initials" id="avatarInitials">?</div>
              <div class="avatar-cam">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              </div>
            </div>
            <div class="avatar-hint">Upload photo</div>
          </div>
          <div class="avatar-name-col">
            <div class="field" style="margin-bottom:0">
              <label class="flabel">Full Name *</label>
              <input class="finput" id="iName" type="text" placeholder="Jane Smith" oninput="updateInitials()">
            </div>
            <div class="field" style="margin-bottom:0">
              <label class="flabel">Title / Role</label>
              <input class="finput" id="iTitle" type="text" placeholder="Senior Product Manager">
            </div>
          </div>
        </div>
        <div class="fields-2">
          <div class="field" style="margin-bottom:0"><label class="flabel">City</label><input class="finput" id="iCity" type="text" placeholder="Chicago, IL"></div>
          <div class="field" style="margin-bottom:0"><label class="flabel">Email</label><input class="finput" id="iEmail" type="email" placeholder="jane@example.com"></div>
        </div>

        <p class="form-section-title" style="margin-top:1.5rem;">Social Links</p>
        <div class="socials-grid">
          <div class="social-field"><span class="social-icon">in</span><input class="social-input" id="sLinkedIn" placeholder="LinkedIn URL"></div>
          <div class="social-field"><span class="social-icon">⌂</span><input class="social-input" id="sPortfolio" placeholder="Portfolio URL"></div>
          <div class="social-field"><span class="social-icon">gh</span><input class="social-input" id="sGithub" placeholder="GitHub URL"></div>
          <div class="social-field"><span class="social-icon">𝕏</span><input class="social-input" id="sTwitter" placeholder="X / Twitter URL"></div>
          <div class="social-field"><span class="social-icon">▶</span><input class="social-input" id="sTiktok" placeholder="TikTok URL"></div>
          <div class="social-field"><span class="social-icon">◻</span><input class="social-input" id="sInstagram" placeholder="Instagram URL"></div>
        </div>

        <p class="form-section-title" style="margin-top:1.5rem;">Profile Theme</p>
        <div class="theme-picker">
          <div class="theme-card on" data-theme="classic" onclick="pickTheme('classic',this)">
            <div class="theme-preview" style="background:#F7F6F3;border:1px solid #E2DED8;"><div style="width:55%;height:6px;background:#1A1A1A;border-radius:2px;margin-bottom:4px;"></div><div style="width:80%;height:2px;background:#E2DED8;border-radius:2px;"></div></div>
            <div class="theme-label">Classic</div><div class="theme-desc">Clean & professional</div>
          </div>
          <div class="theme-card" data-theme="dark" onclick="pickTheme('dark',this)">
            <div class="theme-preview" style="background:#111111;"><div style="width:55%;height:6px;background:#ffffff;border-radius:2px;margin-bottom:4px;"></div><div style="width:40%;height:4px;background:#CCFF00;border-radius:2px;"></div></div>
            <div class="theme-label">Dark</div><div class="theme-desc">Bold & striking</div>
          </div>
          <div class="theme-card" data-theme="bold" onclick="pickTheme('bold',this)">
