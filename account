<script>
const ASK_SERVER = 'https://ask-server.thedobrien.workers.dev';
const WORKER = 'https://spring-pine-fd21.thedobrien.workers.dev/';
let currentSlug = '', maskedEmail = '', avatarDataUrl = null;
let selectedTheme = 'classic', selectedFont = 'classic';
let embedType = 'chat', currentPlatform = 'wix', rawEmbedCode = '';
let shareUrl = '';

// ── PRE-FILL FROM URL PARAM ──
window.addEventListener('load', () => {
  const urlSlug = new URLSearchParams(window.location.search).get('slug');
  if(urlSlug){
    document.getElementById('iSlug').value = urlSlug;
    onSlugInput();
    checkProfile();
  }
  gdprInit();
});

// ── STEP NAVIGATION ──
function onSlugInput(){
  const val = document.getElementById('iSlug').value.trim().toLowerCase();
  document.getElementById('btnStep1').disabled = val.length < 3;
  document.getElementById('slugStatus').textContent = '';
  document.getElementById('profileConfirm').style.display = 'none';
}

async function checkProfile(){
  const slug = document.getElementById('iSlug').value.trim().toLowerCase();
  if(!slug || slug.length < 3) return;
  const status = document.getElementById('slugStatus');
  status.textContent = 'Looking up profile...'; status.className = 'status';
  try {
    const res = await fetch(`${ASK_SERVER}/${slug}`);
    if(res.status === 404){
      status.textContent = '✗ No profile found for "' + slug + '". Check your username and try again.';
      status.className = 'status err';
      document.getElementById('profileConfirm').style.display = 'none';
      return;
    }
    const profile = await res.json();
    currentSlug = slug;
    status.textContent = '';
    document.getElementById('confirmName').textContent = profile.name || slug;
    document.getElementById('confirmMeta').textContent = [profile.title, profile.city].filter(Boolean).join(' · ') || 'ask.menoslabs.com/' + slug;
    document.getElementById('profileConfirm').style.display = 'block';
    setTimeout(() => goToStep(2), 600);
  } catch(e){
    status.textContent = 'Connection error — please try again.';
    status.className = 'status err';
  }
}

async function requestCode(){
  const isResend = document.getElementById('step3').classList.contains('active');
  const btn = isResend ? document.getElementById('btnResend') : document.getElementById('btnRequestCode');
  const status = isResend ? document.getElementById('resendStatus') : document.getElementById('codeRequestStatus');
  btn.disabled = true; btn.textContent = 'Sending...';
  if(status){ status.textContent = ''; status.className = 'status'; }
  try {
    const res = await fetch(`${ASK_SERVER}/request-code`, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({slug: currentSlug})
    });
    const data = await res.json();
    if(!res.ok){
      if(status){ status.textContent = '✗ ' + (data.error || 'Failed to send code.'); status.className = 'status err'; }
      btn.disabled = false;
      btn.textContent = isResend ? 'Resend code' : 'Send Verification Code →';
      return;
    }
    maskedEmail = data.maskedEmail || '';
    if(isResend){
      if(status){ status.textContent = '✓ New code sent to ' + maskedEmail; status.className = 'status ok'; }
      btn.disabled = false; btn.textContent = 'Resend code';
      document.getElementById('iCode').value = '';
      document.getElementById('btnVerify').disabled = true;
    } else {
      document.getElementById('maskedEmailDisplay2').textContent = 'Code sent to ' + maskedEmail;
      goToStep(3);
    }
  } catch(e){
    if(status){ status.textContent = 'Connection error — please try again.'; status.className = 'status err'; }
    btn.disabled = false;
    btn.textContent = isResend ? 'Resend code' : 'Send Verification Code →';
  }
}

function onCodeInput(){
  document.getElementById('btnVerify').disabled = document.getElementById('iCode').value.trim().length < 6;
}

async function verifyCode(){
  const code = document.getElementById('iCode').value.trim().toUpperCase();
  const status = document.getElementById('codeStatus');
  const btn = document.getElementById('btnVerify');
  btn.disabled = true; btn.textContent = 'Verifying...'; status.textContent = '';
  try {
    const res = await fetch(`${ASK_SERVER}/verify-code`, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({slug: currentSlug, code})
    });
    const data = await res.json();
    if(!res.ok){
      status.textContent = '✗ ' + (data.error || 'Invalid code.');
      status.className = 'status err';
      btn.disabled = false; btn.textContent = 'Verify & Manage My Account →';
      return;
    }
    prefillForm(data.profile);
    goToStep(4);
  } catch(e){
    status.textContent = 'Connection error — please try again.';
    status.className = 'status err';
    btn.disabled = false; btn.textContent = 'Verify & Manage My Account →';
  }
}

function goToStep(n){
  document.querySelectorAll('.step').forEach((s,i) => s.classList.toggle('active', i+1 === n));
  if(n === 2){
    const confirmName = document.getElementById('confirmName').textContent;
    document.getElementById('maskedEmailDisplay').textContent = 'We\'ll send a code to the email on file for ' + confirmName + '.';
    document.getElementById('btnRequestCode').disabled = false;
    document.getElementById('btnRequestCode').textContent = 'Send Verification Code →';
  }
}

// ── PREFILL FORM ──
function prefillForm(p){
  document.getElementById('iName').value = p.name || '';
  document.getElementById('iTitle').value = p.title || '';
  document.getElementById('iCity').value = p.city || '';
  document.getElementById('iEmail').value = p.email || '';
  document.getElementById('iResume').value = p.resume || '';
  document.getElementById('sLinkedIn').value = p.socials?.linkedin || '';
  document.getElementById('sPortfolio').value = p.socials?.portfolio || '';
  document.getElementById('sGithub').value = p.socials?.github || '';
  document.getElementById('sTwitter').value = p.socials?.twitter || '';
  document.getElementById('sTiktok').value = p.socials?.tiktok || '';
  document.getElementById('sInstagram').value = p.socials?.instagram || '';
  document.getElementById('editSlugBadge').textContent = currentSlug;

  // Share URL
  shareUrl = 'https://ask.menoslabs.com/' + currentSlug;
  document.getElementById('shareUrl').textContent = shareUrl;
  document.getElementById('viewPageBtn').href = shareUrl;
  renderPlatformContent();

  // Theme
  if(p.theme){ selectedTheme = p.theme; document.querySelectorAll('.theme-card').forEach(c => c.classList.toggle('on', c.dataset.theme === p.theme)); }

  // Font
  if(p.font){ selectedFont = p.font; document.querySelectorAll('.font-card').forEach(c => c.classList.toggle('on', c.dataset.font === p.font)); }

  // Avatar
  avatarDataUrl = p.avatar || null;
  if(p.avatar){
    document.getElementById('avatarCircle').innerHTML = `<img src="${p.avatar}" alt="avatar"><div class="avatar-cam"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>`;
  } else { updateInitials(); }
}

