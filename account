// ── PDF UPLOAD & TEXT EXTRACTION ──
function switchResumeTab(tab){
  document.getElementById('rtab-upload').classList.toggle('on', tab==='upload');
  document.getElementById('rtab-paste').classList.toggle('on', tab==='paste');
  document.getElementById('rpanel-upload').style.display = tab==='upload' ? 'block' : 'none';
  document.getElementById('rpanel-paste').style.display = tab==='paste' ? 'block' : 'none';
}

document.addEventListener('DOMContentLoaded', () => {
  const pdfInp = document.getElementById('pdfInput');
  if(pdfInp) pdfInp.addEventListener('change', function(){
    const file = this.files[0];
    if(file) processPdf(file);
  });
});

function handlePdfDrop(e){
  e.preventDefault();
  document.getElementById('pdfDropZone').style.borderColor = '';
  const file = e.dataTransfer.files[0];
  if(file && file.type === 'application/pdf') processPdf(file);
  else showPdfError('Please drop a PDF file.');
}

async function processPdf(file){
  const statusEl = document.getElementById('pdfExtractStatus');
  const pdfStatus = document.getElementById('pdfStatus');
  pdfStatus.style.display = 'block';
  pdfStatus.textContent = 'Extracting text...';
  pdfStatus.style.color = 'var(--text2)';
  statusEl.style.display = 'none';
  try {
    if(!window.pdfjsLib){
      await new Promise((res, rej) => {
        const s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
        s.onload = res; s.onerror = rej;
        document.head.appendChild(s);
      });
    }
    window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;
    let fullText = '';
    for(let i = 1; i <= pdf.numPages; i++){
      const page = await pdf.getPage(i);
      const content = await page.getTextContent();
      const pageText = content.items.map(item => item.str).join(' ');
      fullText += pageText + '\n';
    }
    fullText = fullText.replace(/  +/g, ' ').replace(/\n +/g, '\n').trim();
    if(fullText.length < 50){
      showPdfError('Could not extract readable text — this PDF may be scanned or image-based. Please paste your resume text instead.');
      return;
    }
    document.getElementById('iResume').value = fullText;
    switchResumeTab('paste');
    pdfStatus.textContent = '\u2713 ' + file.name;
    pdfStatus.style.color = 'var(--accent-dark)';
    statusEl.style.display = 'block';
    statusEl.style.borderColor = 'rgba(138,179,0,0.3)';
    statusEl.style.background = 'rgba(138,179,0,0.05)';
    statusEl.innerHTML = '<strong style="color:var(--accent-dark);">\u2713 Text extracted from ' + file.name + '</strong><br><span style="color:var(--text2);">Review and edit below before generating. Remove anything that looks garbled.</span>';
  } catch(err){
    showPdfError('Could not read this PDF. Please paste your resume text instead.');
  }
}

function showPdfError(msg){
  const pdfStatus = document.getElementById('pdfStatus');
  const statusEl = document.getElementById('pdfExtractStatus');
  pdfStatus.style.display = 'block';
  pdfStatus.textContent = '\u2717 ' + msg;
  pdfStatus.style.color = '#e05c5c';
  statusEl.style.display = 'block';
  statusEl.style.borderColor = '#fca5a5';
  statusEl.style.background = '#fef2f2';
  statusEl.innerHTML = '<span style="color:#dc2626;">' + msg + '</span>';
}

