<script>
function toggleFaq(el){
  const item = el.parentElement;
  item.classList.toggle('open');
}

function switchPlatform(name, btn){
  document.querySelectorAll('.ptab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.platform-panel').forEach(p=>p.classList.remove('on'));
  document.getElementById('platform-'+name).classList.add('on');
}

function copyCode(id, btn){
  const text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text).then(()=>{
    btn.textContent='Copied!'; btn.classList.add('copied');
    setTimeout(()=>{ btn.textContent='Copy Code'; btn.classList.remove('copied'); }, 2000);
  });
}

async function submitContact(e){
  e.preventDefault();
  const btn = document.getElementById('contactBtn');
  btn.textContent='Sending...'; btn.disabled=true;
  try{
    await fetch('https://menoslabs-contact.thedobrien.workers.dev',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        name: document.getElementById('cName').value,
        email: document.getElementById('cEmail').value,
        company: document.getElementById('cSubject').value,
        message: document.getElementById('cMessage').value
      })
    });
  }catch(e){}
  document.querySelector('.contact-form').querySelectorAll('.contact-input, .contact-btn').forEach(el=>el.style.display='none');
  document.getElementById('contactSuccess').style.display='block';
}

// GDPR

function gdprInit(){
  const c=localStorage.getItem('gdpr_consent');
  if(!c) setTimeout(()=>{const b=document.getElementById('gdpr-banner');if(b)b.classList.add('show');},1500);
  if(c==='declined') window['ga-disable-G-Y6Y16FEG2H']=true;
}
function gdprAccept(){localStorage.setItem('gdpr_consent','accepted');const b=document.getElementById('gdpr-banner');if(b)b.classList.remove('show');}
function gdprDecline(){localStorage.setItem('gdpr_consent','declined');window['ga-disable-G-Y6Y16FEG2H']=true;const b=document.getElementById('gdpr-banner');if(b)b.classList.remove('show');}
gdprInit();
// Show real slug if passed in URL
const urlSlug = new URLSearchParams(window.location.search).get('slug');
if(urlSlug){
  const el = document.getElementById('faq-slug-example');
  if(el) el.textContent = 'ask.menoslabs.com/' + urlSlug;
  // Also update embed codes
  document.querySelectorAll('.code-block, .faq-modal-code').forEach(el=>{
    el.textContent = el.textContent.replace('YOUR-SLUG', urlSlug);
  });
}
</script>
</body>
</html>
