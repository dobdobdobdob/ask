      <div class="contact-success" id="contactSuccess">Message sent — we'll be in touch within 24 hours.</div>
    </form>
  </div>
</div>

<!-- GDPR Banner -->
<div id="gdpr-banner">
  <div class="gdpr-text">We use cookies to understand how visitors use our site.</div>
  <div class="gdpr-btns">
    <button class="gdpr-decline" onclick="gdprDecline()">Decline</button>
    <button class="gdpr-accept" onclick="gdprAccept()">Accept</button>
  </div>
</div>
