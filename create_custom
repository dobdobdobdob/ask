<script>
const WORKER = 'https://spring-pine-fd21.thedobrien.workers.dev/';
const SELECTED_PLAN = 'custom';
let selectedFont = 'classic';

function applyCreateColors(){
  const accent = document.getElementById('cAccent').value;
  const bg = document.getElementById('cBg').value;
  const button = document.getElementById('cButton').value;
  const accentDark = darkenColor(accent, 0.3);
  const buttonText = getColorLuminance(button) > 0.4 ? '#111111' : '#ffffff';
  let el = document.getElementById('create-color-override');
  if(!el){ el = document.createElement('style'); el.id='create-color-override'; document.head.appendChild(el); }
  el.textContent = `
    :root { --accent:${accent}; --accent-dark:${accentDark}; }
    .page { background:${bg}!important; }
    .form-card { background:${bg === '#F7F6F3' ? 'var(--white)' : lightenColor(bg, 0.1)}!important; }
    .nav-logo span { background:${accent}!important; }
    .btn-generate { background:${button}!important; color:${buttonText}!important; }
    .btn-generate:hover { background:${accent}!important; color:#111!important; }
    .finput:focus { border-color:${accentDark}!important; }
  `;
}
function darkenColor(hex, amt){ const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return '#'+[r,g,b].map(v=>Math.max(0,Math.round(v*(1-amt))).toString(16).padStart(2,'0')).join(''); }
function lightenColor(hex, amt){ const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16); return '#'+[r,g,b].map(v=>Math.min(255,Math.round(v+(255-v)*amt)).toString(16).padStart(2,'0')).join(''); }
function getColorLuminance(hex){ const r=parseInt(hex.slice(1,3),16)/255,g=parseInt(hex.slice(3,5),16)/255,b=parseInt(hex.slice(5,7),16)/255; return 0.299*r+0.587*g+0.114*b; }
let avatarDataUrl = null;

document.getElementById('avatarInput').addEventListener('change', function(){
  const file = this.files[0]; if(!file) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = 200; canvas.height = 200;
      const ctx = canvas.getContext('2d');
      const size = Math.min(img.width, img.height);
      const sx = (img.width - size) / 2;
      const sy = (img.height - size) / 2;
      ctx.drawImage(img, sx, sy, size, size, 0, 0, 200, 200);
      avatarDataUrl = canvas.toDataURL('image/jpeg', 0.8);
      document.getElementById('avatarCircle').innerHTML = `<img src="${avatarDataUrl}" alt="avatar">`;
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(file);
});

function updateInitials(){
  const el = document.getElementById('avatarInitials');
  if(!el) return;
  const n = document.getElementById('iName').value.trim();
  const p = n.split(' ').filter(Boolean);
  const i = p.length>=2 ? p[0][0]+p[p.length-1][0] : p[0]?.[0]||'?';
  el.textContent = i.toUpperCase();
}



const ASK_SERVER = 'https://ask-server.thedobrien.workers.dev';
let chosenUsername = '';
let usernameValid = false;
let usernameCheckTimer = null;

function sanitizeUsername(val){
  return val.toLowerCase().replace(/[^a-z0-9\-_]/g, '').slice(0, 30);
}

function onUsernameInput(){
  const raw = document.getElementById('iUsername').value;
  const clean = sanitizeUsername(raw);
  // Keep cursor position by only updating if changed
  if(raw !== clean) document.getElementById('iUsername').value = clean;
  document.getElementById('urlPreview').textContent = clean || 'username';
  document.getElementById('usernameSuggestions').innerHTML = '';
  usernameValid = false;
  chosenUsername = '';
  const status = document.getElementById('usernameStatus');
  if(!clean){ status.textContent = ''; status.className = 'username-status'; return; }
  if(clean.length < 3){ status.textContent = 'Must be at least 3 characters'; status.className = 'username-status taken'; return; }
  status.textContent = 'Checking availability...';
  status.className = 'username-status checking';
  clearTimeout(usernameCheckTimer);
  usernameCheckTimer = setTimeout(()=>checkUsername(), 600);
}

async function checkUsername(){
  const val = document.getElementById('iUsername').value;
  const clean = sanitizeUsername(val);
  if(!clean || clean.length < 3) return;
  const status = document.getElementById('usernameStatus');
  const suggsEl = document.getElementById('usernameSuggestions');
  status.textContent = 'Checking...';
  status.className = 'username-status checking';
  try {
    const res = await fetch(`${ASK_SERVER}/${clean}`);
    if(res.status === 404){
      // Available
      status.textContent = '✓ Available!';
      status.className = 'username-status available';
      suggsEl.innerHTML = '';
      chosenUsername = clean;
      usernameValid = true;
    } else {
      // Taken — show suggestions
      status.textContent = '✗ Already taken. Try one of these:';
      status.className = 'username-status taken';
      usernameValid = false;
      chosenUsername = '';
      const suggestions = [
        clean + new Date().getFullYear().toString().slice(2),
        clean + Math.floor(Math.random()*900+100),
        clean + '_pro',
      ];
      suggsEl.innerHTML = suggestions.map(s =>
        `<button class="username-sugg" onclick="selectSuggestion('${s}')">${s}</button>`
      ).join('');
    }
  } catch(e) {
    status.textContent = 'Could not check — please try again.';
    status.className = 'username-status taken';
  }
}

async function selectSuggestion(slug){
  document.getElementById('iUsername').value = slug;
  document.getElementById('urlPreview').textContent = slug;
  document.getElementById('usernameSuggestions').innerHTML = '';
  const status = document.getElementById('usernameStatus');
  status.textContent = 'Checking...';
  status.className = 'username-status checking';
  try {
    const res = await fetch(`${ASK_SERVER}/${slug}`);
    if(res.status === 404){
      status.textContent = '✓ Available!';
      status.className = 'username-status available';
      chosenUsername = slug;
      usernameValid = true;
    } else {
      status.textContent = '✗ Also taken — please try another.';
      status.className = 'username-status taken';
    }
  } catch(e) {
    status.textContent = 'Could not check — please try again.';
    status.className = 'username-status taken';
  }
}

async function generate(){
  const name = document.getElementById('iName').value.trim().replace(/[^a-zA-Z0-9\s\-]/g, '').trim();
  const title = document.getElementById('iTitle').value.trim();
  const city = document.getElementById('iCity').value.trim();
  const email = document.getElementById('iEmail').value.trim();
  const rawResume = document.getElementById('iResume').value.trim();
  const resume = rawResume
    .replace(/\+?[\d][\d\s\-().]{7,}[\d]/g, '[phone removed]')
    .replace(/\d+\s+[A-Za-z0-9\s,\.]+(?:Street|St|Avenue|Ave|Road|Rd|Boulevard|Blvd|Drive|Dr|Lane|Ln|Court|Ct|Way|Place|Pl|Circle|Cir|Trail|Tr|Parkway|Pkwy|Highway|Hwy)[^\n]*/gi, '[address removed]')
    .replace(/\b[A-Za-z\s]+,\s*[A-Z]{2}\s+\d{5}(?:-\d{4})?\b/g, '[address removed]')
    .trim();

  if(!usernameValid || !chosenUsername){ alert('Please choose an available username above.'); return; }
  if(!name){ alert('Please enter your name.'); return; }
  if(!resume){ alert('Please paste your resume text above.'); return; }
  if(resume.length < 100){ alert('Resume content seems too short. Please paste your full resume text for best results.'); return; }

  const socials = {
    linkedin: document.getElementById('sLinkedIn').value.trim(),
    portfolio: document.getElementById('sPortfolio').value.trim(),
    github: document.getElementById('sGithub').value.trim(),
    twitter: document.getElementById('sTwitter').value.trim(),
    tiktok: document.getElementById('sTiktok').value.trim(),
    instagram: document.getElementById('sInstagram').value.trim(),
  };

  document.getElementById('formActions').style.display='none';
  document.getElementById('processing').style.display='block';

  const texts = ['Reading your resume...','Extracting experience...','Building your assistant...','Almost ready...'];
  let gi=0;
  const iv = setInterval(()=>{ gi=(gi+1)%texts.length; document.getElementById('procText').textContent=texts[gi]; }, 1800);

  try {
    const res = await fetch(WORKER, {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:16000,
        messages:[{role:'user', content:
`You are parsing a resume. CRITICAL RULES:
- Only use information explicitly stated in the resume text below
- Do NOT invent, assume, or hallucinate any companies, roles, dates, or achievements
- If the resume text looks garbled or unreadable, return an error field instead
- Only include companies and roles that are clearly named in the text
- Do NOT include any physical addresses or phone numbers in any field

Resume for ${name}:
---
${resume}
---

Respond with ONLY a valid JSON object (no markdown, no backticks):
{
  "bio": "2-3 sentence bio using ONLY facts from the resume above. Third person.",
  "experience": [
    {
      "company": "EXACT company name from resume only",
      "role": "EXACT job title from resume only",
      "dates": "dates as written in resume",
      "location": "city and state only, no street addresses",
      "bullets": ["achievement or responsibility exactly as described in resume"]
    }
  ],
  "education": [
    {
      "institution": "EXACT school name from resume only",
      "degree": "degree and field as written in resume",
      "dates": "dates as written in resume",
      "location": "city and state only if mentioned"
    }
  ],
  "skills": ["only skills explicitly mentioned in the resume"],
  "systemPrompt": "You are a professional AI assistant for ${name}. Only discuss what is in their resume. If asked about something not in their background, say you don't have that information. Background from resume: [paste all key facts from the resume here]"
}`
        }]
      })
    });

    const data = await res.json();
    const raw = data.content?.[0]?.text || '{}';
    let parsed;
    try { parsed = JSON.parse(raw); }
    catch(e){ const m=raw.match(/\{[\s\S]*\}/); parsed=m?JSON.parse(m[0]):{bio:'',experience:[],skills:[],systemPrompt:`You are an AI assistant for ${name}.`}; }

    clearInterval(iv);

    const cAccent = document.getElementById('cAccent').value;
    const cBg = document.getElementById('cBg').value;
    const cButton = document.getElementById('cButton').value;
    const customColors = { accent:cAccent, bg:cBg, buttonBg:cButton, accentDark:darkenColor(cAccent,0.3), bgAlt:cBg, buttonText:getColorLuminance(cButton)>0.4?'#111111':'#ffffff' };

    const profileData = { name, title, city, email, socials, bio:parsed.bio, experience:parsed.experience||[], education:parsed.education||[], skills:parsed.skills||[], systemPrompt:parsed.systemPrompt, avatar:avatarDataUrl, chosenUsername, font:selectedFont, resume:resume, plan:'custom', customColors };
    sessionStorage.setItem('ask_draft', JSON.stringify(profileData));
    window.location.href = '/preview_custom.html';

  } catch(err){
    clearInterval(iv);
    document.getElementById('procText').textContent='Something went wrong. Please try again.';
    document.getElementById('formActions').style.display='block';
    document.getElementById('processing').style.display='none';
  }
}
// ── PDF UPLOAD & TEXT EXTRACTION ──
function switchResumeTab(tab){
  document.getElementById('rtab-upload').classList.toggle('on', tab==='upload');
  document.getElementById('rtab-paste').classList.toggle('on', tab==='paste');
  document.getElementById('rpanel-upload').style.display = tab==='upload' ? 'block' : 'none';
  document.getElementById('rpanel-paste').style.display = tab==='paste' ? 'block' : 'none';
}

document.addEventListener('DOMContentLoaded', () => {
  const pdfInp = document.getElementById('pdfInput');
  if(pdfInp) pdfInp.addEventListener('change', function(){
    if(this.files[0]) processPdf(this.files[0]);
  });
});

function handlePdfDrop(e){
  e.preventDefault();
  document.getElementById('pdfDropZone').style.borderColor = '';
  const file = e.dataTransfer.files[0];
  if(file && file.type === 'application/pdf') processPdf(file);
  else showPdfError('Please drop a PDF file.');
}

async function processPdf(file){
  const statusEl = document.getElementById('pdfExtractStatus');
  const pdfStatus = document.getElementById('pdfStatus');
  pdfStatus.style.display = 'block';
  pdfStatus.textContent = 'Extracting text...';
  pdfStatus.style.color = 'var(--text2)';
  statusEl.style.display = 'none';
  try {
    if(!window.pdfjsLib){
      await new Promise((res, rej) => {
        const s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js';
        s.onload = res; s.onerror = rej;
        document.head.appendChild(s);
      });
    }
    window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await window.pdfjsLib.getDocument({ data: arrayBuffer }).promise;
    let fullText = '';
    for(let i = 1; i <= pdf.numPages; i++){
      const page = await pdf.getPage(i);
      const content = await page.getTextContent();
      fullText += content.items.map(item => item.str).join(' ') + '\n';
    }
    fullText = fullText.replace(/  +/g, ' ').replace(/\n +/g, '\n').trim();
    if(fullText.length < 50){
      showPdfError('Could not extract readable text — this PDF may be scanned. Please paste your resume text instead.');
      return;
    }
    document.getElementById('iResume').value = fullText;
    switchResumeTab('paste');
    pdfStatus.textContent = '\u2713 ' + file.name;
    pdfStatus.style.color = 'var(--accent-dark)';
    statusEl.style.display = 'block';
    statusEl.style.borderColor = 'rgba(138,179,0,0.3)';
    statusEl.style.background = 'rgba(138,179,0,0.05)';
    statusEl.innerHTML = '<strong style="color:var(--accent-dark);">\u2713 Text extracted — ' + file.name + '</strong><br><span style="color:var(--text2);">Review the text below, then click <strong>Generate My Assistant \u2192</strong></span>';
    // Scroll generate button into view
    setTimeout(() => { const btn = document.querySelector('.btn-generate'); if(btn) btn.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 400);
  } catch(err){
    showPdfError('Could not read this PDF. Please paste your resume text instead.');
  }
}

function showPdfError(msg){
  const s = document.getElementById('pdfStatus');
  const e = document.getElementById('pdfExtractStatus');
  s.style.display='block'; s.textContent='\u2717 '+msg; s.style.color='#e05c5c';
  e.style.display='block'; e.style.borderColor='#fca5a5'; e.style.background='#fef2f2';
  e.innerHTML='<span style="color:#dc2626;">'+msg+'</span>';
}

